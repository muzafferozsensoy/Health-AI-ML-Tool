# Frontend env example — copy to .env and adjust as needed.
# These are read by Vite at build time (VITE_ prefix is required).

# Backend API base URL.
# Local dev: http://localhost:8000/api
# Docker compose: /api  (handled via nginx proxy)
# Production: https://your-backend.onrender.com/api
VITE_API_URL=http://localhost:8000/api
